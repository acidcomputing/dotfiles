# :: a c i d c o m p u t i n g :: 
# zsh aliases

# navigation
alias ll='ls -l'
alias lsa='ls -la'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'

# editors
alias e='emacsclient -nw'

# personal
alias ff='fastfetch'
alias fetch='fastfetch --config none'
alias :q='exit'
alias tlscl='tailscale'

# power
alias byebye='sudo shutdown now'
alias zzz='systemctl sleep'

# other
alias py='python3'
